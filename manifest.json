{
  "manifest_version": 3,
  "name": "Webtoon Tracker",
  "version": "1.3",
  "description": "Sauvegarde automatique du dernier chapitre lu.",
  "icons": {
    "128": "assets/webtoon-tracker-icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/webtoon-tracker-icon.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.webtoons.com/*/viewer*",
        "*://*.webtoons.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "contact@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}